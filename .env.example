# ─── Anthropic Claude API ─────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Vercel KV (Redis) ────────────────────────────────────────────────────────
# Create a KV store at: https://vercel.com/dashboard > Storage > Create KV
# Then copy the credentials from the store's "Quickstart" tab.
# Without these, the app falls back to in-memory caching (works for dev/preview).
KV_REST_API_URL=https://your-kv-store.kv.vercel-storage.com
KV_REST_API_TOKEN=your_kv_rest_api_token

# ─── Optional: Node environment ───────────────────────────────────────────────
NODE_ENV=development
